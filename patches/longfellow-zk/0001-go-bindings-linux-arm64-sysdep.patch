diff --git a/lib/algebra/sysdep.h b/lib/algebra/sysdep.h
--- a/lib/algebra/sysdep.h
+++ b/lib/algebra/sysdep.h
@@ -126,6 +126,62 @@ static inline void mulq(uint64_t* l, uint64_t* h, uint64_t a, uint64_t b) {
 #else  // defined(__SIZEOF_INT128__)
 #define SYSDEP_MULQ64_NOT_DEFINED
 #endif  // defined(__SIZEOF_INT128__)
+#elif defined(__SIZEOF_INT128__)
+// Portable fallback for non-x86 GCC targets such as Linux/aarch64. The clang
+// branch above uses compiler builtins; GCC does not provide those carry
+// builtins, so use widened arithmetic instead.
+static inline unsigned long long adc(unsigned long long* a,
+                                     unsigned long long b,
+                                     unsigned long long c) {
+  constexpr unsigned kBits = sizeof(*a) * 8;
+  __uint128_t sum = static_cast<__uint128_t>(*a) + b + c;
+  *a = static_cast<unsigned long long>(sum);
+  return static_cast<unsigned long long>(sum >> kBits);
+}
+static inline unsigned long adc(unsigned long* a, unsigned long b,
+                                unsigned long c) {
+  constexpr unsigned kBits = sizeof(*a) * 8;
+  __uint128_t sum = static_cast<__uint128_t>(*a) + b + c;
+  *a = static_cast<unsigned long>(sum);
+  return static_cast<unsigned long>(sum >> kBits);
+}
+static inline unsigned int adc(unsigned int* a, unsigned int b,
+                               unsigned int c) {
+  uint64_t sum = static_cast<uint64_t>(*a) + b + c;
+  *a = static_cast<unsigned int>(sum);
+  return static_cast<unsigned int>(sum >> 32);
+}
+
+static inline unsigned long long sbb(unsigned long long* a,
+                                     unsigned long long b,
+                                     unsigned long long c) {
+  __uint128_t minuend = *a;
+  __uint128_t subtrahend = static_cast<__uint128_t>(b) + c;
+  *a = static_cast<unsigned long long>(minuend - subtrahend);
+  return minuend < subtrahend ? 1 : 0;
+}
+static inline unsigned long sbb(unsigned long* a, unsigned long b,
+                                unsigned long c) {
+  __uint128_t minuend = *a;
+  __uint128_t subtrahend = static_cast<__uint128_t>(b) + c;
+  *a = static_cast<unsigned long>(minuend - subtrahend);
+  return minuend < subtrahend ? 1 : 0;
+}
+static inline unsigned int sbb(unsigned int* a, unsigned int b,
+                               unsigned int c) {
+  uint64_t minuend = *a;
+  uint64_t subtrahend = static_cast<uint64_t>(b) + c;
+  *a = static_cast<unsigned int>(minuend - subtrahend);
+  return minuend < subtrahend ? 1 : 0;
+}
+
+static inline void mulq(uint64_t* l, uint64_t* h, uint64_t a, uint64_t b) {
+  __uint128_t p = static_cast<__uint128_t>(b) * static_cast<__uint128_t>(a);
+  *l = p;
+  *h = p >> 64;
+}
+#else
+#define SYSDEP_MULQ64_NOT_DEFINED
 #endif
 
 static inline void mulq(uint32_t* l, uint32_t* h, uint32_t a, uint32_t b) {
@@ -366,7 +422,7 @@ static inline uint32_t sub_sysdep(uint32_t a, uint32_t y, uint32_t m) {
